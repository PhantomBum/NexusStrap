<Page
    x:Class="NexusStrap.UI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{Binding RobloxStatus}" Opacity="0.6" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button Content="Play" FontSize="15" FontWeight="SemiBold"
                               Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                               Command="{Binding LaunchRobloxCommand}" Margin="0,0,8,0"
                               ToolTip="Launch Roblox home (same as Voidstrap / Bloxstrap desktop app)" />
                    <ui:Button Content="Roblox.com" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary"
                               Command="{Binding OpenRobloxWebsiteCommand}"
                               ToolTip="Open Roblox in your browser" />
                </StackPanel>
            </Grid>

            <!-- Metric Cards -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="FPS" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CurrentFps, StringFormat='{}{0:F0}'}" FontSize="32" FontWeight="Bold" Foreground="#7C3AED" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CurrentCpu, StringFormat='{}{0:F1}%'}" FontSize="32" FontWeight="Bold" Foreground="#06B6D4" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CurrentRam, StringFormat='{}{0} MB'}" FontSize="32" FontWeight="Bold" Foreground="#F59E0B" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Ping" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CurrentPing, StringFormat='{}{0:F0} ms'}" FontSize="32" FontWeight="Bold" Foreground="#10B981" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CurrentGpu, StringFormat='{}{0:F1}%'}" FontSize="32" FontWeight="Bold" Foreground="#EF4444" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts -->
            <Grid Height="200" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="FPS History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding FpsSeries}" Height="150" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="CPU History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding CpuSeries}" Height="150" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RAM History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding RamSeries}" Height="150" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Quick Optimization" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Performance" Icon="{ui:SymbolIcon TopSpeed24}" Appearance="Danger"
                                   Command="{Binding ApplyPerformanceModeCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Balanced" Icon="{ui:SymbolIcon Scales24}" Appearance="Primary"
                                   Command="{Binding ApplyBalancedModeCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Quality" Icon="{ui:SymbolIcon Sparkle24}" Appearance="Success"
                                   Command="{Binding ApplyQualityModeCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session Info + Bottleneck -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Session Info" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CurrentGame, StringFormat='Game: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CurrentServer, StringFormat='Server: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ServerRegion, StringFormat='Region: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SessionTime, StringFormat='Session: {0}'}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="System Analysis" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding BottleneckStatus}" TextWrapping="Wrap" Opacity="0.8" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
