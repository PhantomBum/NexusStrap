<Page
    x:Class="NexusStrap.UI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:lcm="clr-namespace:LiveChartsCore.Measure;assembly=LiveChartsCore">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24,20,24,28">
        <StackPanel>
            <!-- Voidstrap / Bloxstrap-style hero: bold launch strip -->
            <Border CornerRadius="12" Margin="0,0,0,24" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1520" Offset="0" />
                        <GradientStop Color="#121826" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="HOME" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeMutedTextBrush}" />
                        <TextBlock Text="Launch" FontSize="24" FontWeight="Bold" Margin="0,6,0,6" />
                        <TextBlock Text="{Binding RobloxStatus}" FontSize="13" Foreground="{DynamicResource ThemeMutedTextBrush}" TextWrapping="Wrap" MaxWidth="520" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="Play" MinWidth="128" Height="40" FontSize="15" FontWeight="SemiBold"
                                   Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                                   Command="{Binding LaunchRobloxCommand}" Margin="0,0,10,0"
                                   ToolTip="Run bootstrap and open Roblox (same flow as Voidstrap / Bloxstrap)" />
                        <ui:Button Content="Website" MinHeight="40" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary"
                                   Command="{Binding OpenRobloxWebsiteCommand}"
                                   ToolTip="Open roblox.com in your browser" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Metric Cards -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">
                <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FPS" Foreground="{DynamicResource ThemeMutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentFps, StringFormat='{}{0:F0}'}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="16" Margin="4,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="{DynamicResource ThemeMutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentCpu, StringFormat='{}{0:F1}%'}" FontSize="32" FontWeight="Bold" Foreground="#38BDF8" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="16" Margin="4,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="RAM" Foreground="{DynamicResource ThemeMutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentRam, StringFormat='{}{0} MB'}" FontSize="32" FontWeight="Bold" Foreground="#FBBF24" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="16" Margin="4,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Ping" Foreground="{DynamicResource ThemeMutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentPing, StringFormat='{}{0:F0} ms'}" FontSize="32" FontWeight="Bold" Foreground="#34D399" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GPU" Foreground="{DynamicResource ThemeMutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding CurrentGpu, StringFormat='{}{0:F1}%'}" FontSize="32" FontWeight="Bold" Foreground="#F87171" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts (zoom off so mouse wheel scrolls the page) -->
            <Grid Height="200" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="12" Margin="0,0,8,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FPS History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding FpsSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="12" Margin="4,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CPU History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding CpuSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="12" Margin="8,0,0,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="RAM History" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding RamSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Quick optimization" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Performance" Icon="{ui:SymbolIcon TopSpeed24}" Appearance="Danger"
                                   Command="{Binding ApplyPerformanceModeCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Balanced" Icon="{ui:SymbolIcon Scales24}" Appearance="Primary"
                                   Command="{Binding ApplyBalancedModeCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Quality" Icon="{ui:SymbolIcon Sparkle24}" Appearance="Success"
                                   Command="{Binding ApplyQualityModeCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session Info + Bottleneck -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="20" Margin="0,0,8,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Session" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CurrentGame, StringFormat='Game: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CurrentServer, StringFormat='Server: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ServerRegion, StringFormat='Region: {0}'}" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SessionTime, StringFormat='Session: {0}'}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource ThemeSurfaceElevatedBrush}" CornerRadius="8" Padding="20" Margin="8,0,0,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Analysis" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding BottleneckStatus}" TextWrapping="Wrap" Foreground="{DynamicResource ThemeMutedTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
