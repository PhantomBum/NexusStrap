<Page
    x:Class="NexusStrap.UI.Views.Pages.SocialPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <TextBlock Text="Social &amp; Integration" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <!-- Discord -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Discord" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,8">
                        <TextBlock Text="Rich Presence" VerticalAlignment="Center" />
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding DiscordEnabled, Mode=TwoWay}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
                        <ui:Button Content="Connect" Icon="{ui:SymbolIcon PlugConnected24}" Appearance="Primary" Command="{Binding ConnectDiscordCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Disconnect" Icon="{ui:SymbolIcon PlugDisconnected24}" Appearance="Secondary" Command="{Binding DisconnectDiscordCommand}" />
                    </StackPanel>
                    <TextBlock Opacity="0.75" Margin="0,0,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Connection: Disconnected" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiscordConnected}" Value="True">
                                        <Setter Property="Text" Value="Connection: Connected" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Margin="0,8">
                        <TextBlock Text="Show game in RPC" VerticalAlignment="Center" />
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding ShowGameInRpc, Mode=TwoWay}" />
                    </Grid>
                    <Grid Margin="0,8">
                        <TextBlock Text="Show server in RPC" VerticalAlignment="Center" />
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding ShowServerInRpc, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Activity sharing -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Activity Sharing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button Content="Generate link" Icon="{ui:SymbolIcon Link24}" Appearance="Primary" Command="{Binding GenerateJoinLinkCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Copy link" Icon="{ui:SymbolIcon Copy24}" Appearance="Secondary" Command="{Binding CopyJoinLinkCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding JoinLink}" TextWrapping="Wrap" Opacity="0.85" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
