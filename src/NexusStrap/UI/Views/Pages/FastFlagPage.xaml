<Page
    x:Class="NexusStrap.UI.Views.Pages.FastFlagPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <TextBlock Text="FastFlags" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Search" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ui:TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Filter by flag name…" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Active flags" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding Flags}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              MaxHeight="320" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="160" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" MinWidth="80" />
                            <DataGridTemplateColumn Header="" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:Button Content="Remove" Appearance="Secondary"
                                                   Command="{Binding DataContext.RemoveFlagCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding Name}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Add flag" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Name" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewFlagName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Text="Value" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewFlagValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <ui:Button Content="Add flag" Icon="{ui:SymbolIcon Add24}" Appearance="Primary"
                               HorizontalAlignment="Left" Command="{Binding AddFlagCommand}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Presets" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Button Margin="0,0,8,8"
                                           Content="{Binding Name}"
                                           ToolTip="{Binding Description}"
                                           Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Import / export" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Import" Icon="{ui:SymbolIcon ArrowImport24}" Appearance="Secondary"
                                     Command="{Binding ImportFlagsCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Export" Icon="{ui:SymbolIcon ArrowExport24}" Appearance="Secondary"
                                     Command="{Binding ExportFlagsCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Snapshots" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ui:Button Content="Save snapshot" Icon="{ui:SymbolIcon Save24}" Appearance="Primary"
                               HorizontalAlignment="Left" Command="{Binding SaveSnapshotCommand}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding History}" BorderThickness="0" Background="Transparent"
                             AlternationCount="1000">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                        <TextBlock Opacity="0.65" FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:g} · {1} flags">
                                                    <Binding Path="Timestamp" />
                                                    <Binding Path="Flags.Count" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" VerticalAlignment="Center" Content="Restore"
                                               Appearance="Secondary"
                                               Command="{Binding DataContext.RestoreSnapshotCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
