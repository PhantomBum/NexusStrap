<Page
    x:Class="NexusStrap.UI.Views.Pages.StabilityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <TextBlock Text="Stability &amp; Debug" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <!-- Diagnostics -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Diagnostics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ui:Button Content="Run Diagnostics" Icon="{ui:SymbolIcon Search24}" Appearance="Primary" HorizontalAlignment="Left" Command="{Binding RunDiagnosticsCommand}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding DiagnosticsReport}" TextWrapping="Wrap" Opacity="0.85" FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <!-- Toggles -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Modes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,8">
                        <TextBlock Text="Safe Mode" VerticalAlignment="Center" />
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding SafeModeActive, Mode=OneWay}" Command="{Binding ToggleSafeModeCommand}" />
                    </Grid>
                    <Grid Margin="0,8">
                        <TextBlock Text="Debug overlay" VerticalAlignment="Center" />
                        <ui:ToggleSwitch HorizontalAlignment="Right" IsChecked="{Binding OverlayActive, Mode=OneWay}" Command="{Binding ToggleOverlayCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Crash reports -->
            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Crash reports" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ui:Button HorizontalAlignment="Right" Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Secondary" Command="{Binding RefreshCrashesCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding CrashReports}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Timestamp}" Opacity="0.65" FontSize="12" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding Preview}" TextWrapping="Wrap" Opacity="0.75" FontSize="12" Margin="0,4,0,0" MaxHeight="48" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" VerticalAlignment="Center" Content="Open" Icon="{ui:SymbolIcon Document24}" Appearance="Secondary"
                                                   Command="{Binding DataContext.OpenCrashReportCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" Margin="12,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
