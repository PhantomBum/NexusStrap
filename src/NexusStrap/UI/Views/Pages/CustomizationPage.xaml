<Page
    x:Class="NexusStrap.UI.Views.Pages.CustomizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="Customization" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Theme mode" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Dark" Icon="{ui:SymbolIcon WeatherMoon24}" Appearance="Primary"
                                   Command="{Binding ApplyDarkThemeCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Light" Icon="{ui:SymbolIcon WeatherSunny24}" Appearance="Secondary"
                                   Command="{Binding ApplyLightThemeCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Available themes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding AvailableThemes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Button
                                    Margin="0,0,8,8"
                                    Padding="12,8"
                                    Content="{Binding Name}"
                                    Command="{Binding DataContext.ApplyThemeCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Background &amp; motion" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button Content="Browse image" Icon="{ui:SymbolIcon Image24}" Appearance="Secondary"
                                   Command="{Binding BrowseBackgroundCommand}" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding CustomBackgroundPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Opacity="0.85" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Background opacity" Opacity="0.7" Margin="0,0,0,4" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding BackgroundOpacity, Mode=TwoWay}" TickFrequency="0.05" IsSnapToTickEnabled="True" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Animations" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:ToggleSwitch IsChecked="{Binding EnableAnimations, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
