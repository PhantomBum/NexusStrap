<Page
    x:Class="NexusStrap.UI.Views.Pages.ModsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Mods" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}" Opacity="0.6" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button
                        Content="Install"
                        Icon="{ui:SymbolIcon Add24}"
                        Appearance="Secondary"
                        Command="{Binding InstallModCommand}"
                        Margin="0,0,8,0" />
                    <ui:Button
                        Content="Apply Mods"
                        Icon="{ui:SymbolIcon Checkmark24}"
                        Appearance="Primary"
                        Command="{Binding ApplyModsCommand}" />
                </StackPanel>
            </Grid>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Installed mods" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Mods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="3">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding Author, StringFormat='By {0}'}" Opacity="0.7" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.85" Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="1"
                                            Grid.Row="0"
                                            Grid.RowSpan="3"
                                            VerticalAlignment="Center"
                                            Margin="16,0,0,0"
                                            Orientation="Vertical">
                                            <ui:ToggleSwitch
                                                Margin="0,0,0,8"
                                                IsChecked="{Binding IsEnabled}"
                                                Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}" />
                                            <ui:Button
                                                Content="Uninstall"
                                                Icon="{ui:SymbolIcon Delete24}"
                                                Appearance="Danger"
                                                Command="{Binding DataContext.UninstallModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Conflicts" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Conflicts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding TargetFile}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Opacity="0.75" Text="Mods: " />
                                        <ItemsControl ItemsSource="{Binding ConflictingMods}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,8,0" Opacity="0.75" Text="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
