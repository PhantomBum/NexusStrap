<Page
    x:Class="NexusStrap.UI.Views.Pages.UtilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <TextBlock Text="Utilities" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Cleaner" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CleanupStatus}" TextWrapping="Wrap" Margin="0,0,0,8" Opacity="0.9" />
                    <TextBlock Text="{Binding CleanableBytes, StringFormat='Recoverable: {0:N0} bytes'}" Margin="0,0,0,12" Opacity="0.75" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Clean all" Icon="{ui:SymbolIcon Delete24}" Appearance="Primary"
                                   Command="{Binding CleanAllCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Clean logs" Icon="{ui:SymbolIcon Document24}" Appearance="Secondary"
                                   Command="{Binding CleanLogsCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Clean downloads" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                   Command="{Binding CleanDownloadsCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Install" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding InstallStatus}" TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.9" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Verify" Icon="{ui:SymbolIcon ShieldCheckmark24}" Appearance="Secondary"
                                   Command="{Binding VerifyInstallCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Repair" Icon="{ui:SymbolIcon Wrench24}" Appearance="Primary"
                                   Command="{Binding RepairInstallCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Version manager" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Versions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource ThemePrimaryBrush}" BorderThickness="1" Opacity="0.95">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding VersionGuid}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="  ·  Current" Foreground="{DynamicResource ThemePrimaryBrush}" FontWeight="SemiBold" Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Opacity="0.75" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Installed {0:g}  ·  {1} MB">
                                                        <Binding Path="InstallDate" />
                                                        <Binding Path="SizeMb" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <ui:Button Content="Switch" Appearance="Secondary"
                                                       Command="{Binding DataContext.SwitchVersionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" Margin="0,0,8,0" />
                                            <ui:Button Content="Delete" Appearance="Danger"
                                                       Command="{Binding DataContext.DeleteVersionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
