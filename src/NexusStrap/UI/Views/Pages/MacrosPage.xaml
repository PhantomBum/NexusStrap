<Page
    x:Class="NexusStrap.UI.Views.Pages.MacrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Macros" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusText}" Opacity="0.6" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Recording" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Margin="0,0,0,4" Opacity="0.75" Text="Macro name (optional)" />
                    <TextBox
                        Margin="0,0,0,12"
                        Padding="8"
                        Text="{Binding RecordingName, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button
                            Content="Start recording"
                            Icon="{ui:SymbolIcon Record24}"
                            Appearance="Danger"
                            Command="{Binding StartRecordingCommand}"
                            Margin="0,0,8,0">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                        <ui:Button
                            Content="Stop recording"
                            Icon="{ui:SymbolIcon Stop24}"
                            Appearance="Primary"
                            Command="{Binding StopRecordingCommand}">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="IsEnabled" Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Saved macros" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Macros}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Opacity="0.75"
                                                Text="{Binding Actions.Count, StringFormat='{}{0} actions'}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="16,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <ui:Button
                                                Content="Play"
                                                Icon="{ui:SymbolIcon Play24}"
                                                Appearance="Primary"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.PlayMacroCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}" />
                                            <ui:Button
                                                Content="Delete"
                                                Icon="{ui:SymbolIcon Delete24}"
                                                Appearance="Danger"
                                                Command="{Binding DataContext.DeleteMacroCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
