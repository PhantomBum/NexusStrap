<Page
    x:Class="NexusStrap.UI.Views.Pages.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <TextBlock Text="Servers" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Secondary"
                               Command="{Binding RefreshServerCommand}" />
                </StackPanel>
            </Grid>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Current server" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding ServerStatus}" Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Opacity="0.6" Text="IP address" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Opacity="0.6" Text="Region" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" Opacity="0.6" Text="Ping" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding CurrentServer.IpAddress, FallbackValue=—}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding CurrentServer.Region, FallbackValue=—}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentServer.PingMs, StringFormat='{}{0:F0} ms', FallbackValue=—}" />
                    </Grid>
                    <Separator Margin="0,16,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Opacity="0.6" Text="Players" />
                        <TextBlock Grid.Column="1">
                            <Run Text="{Binding CurrentServer.PlayerCount, Mode=OneWay, FallbackValue=0}" />
                            <Run Text="/" />
                            <Run Text="{Binding CurrentServer.MaxPlayers, Mode=OneWay, FallbackValue=0}" />
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Join by Place ID" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBox Text="{Binding JoinPlaceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Join" Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                                   Command="{Binding JoinServerCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Server hop" Icon="{ui:SymbolIcon ArrowShuffle24}" Appearance="Secondary"
                                   Command="{Binding ServerHopCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Rejoin" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Secondary"
                                   Command="{Binding RejoinCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Copy deep link" Icon="{ui:SymbolIcon Link24}" Appearance="Secondary"
                                   Command="{Binding CopyDeepLinkCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Matchmaking region" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Pick a region, then apply. Auto uses Roblox defaults." Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <ComboBox Width="280" HorizontalAlignment="Left" Margin="0,0,0,12"
                              SelectedItem="{Binding SelectedRegion, Mode=TwoWay}">
                        <ComboBox.Items>
                            <sys:String>Auto</sys:String>
                            <sys:String>US-East</sys:String>
                            <sys:String>US-West</sys:String>
                            <sys:String>US-Central</sys:String>
                            <sys:String>EU-West</sys:String>
                            <sys:String>EU-Central</sys:String>
                            <sys:String>Asia-Pacific (Singapore)</sys:String>
                            <sys:String>Asia-Pacific (Japan)</sys:String>
                            <sys:String>South America</sys:String>
                            <sys:String>Australia</sys:String>
                        </ComboBox.Items>
                    </ComboBox>
                    <ui:Button Content="Apply region" Icon="{ui:SymbolIcon Globe24}" Appearance="Primary"
                               HorizontalAlignment="Left" Command="{Binding SetRegionCommand}"
                               CommandParameter="{Binding SelectedRegion}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
