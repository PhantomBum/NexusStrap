<Page
    x:Class="NexusStrap.UI.Views.Pages.MonitorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:lcm="clr-namespace:LiveChartsCore.Measure;assembly=LiveChartsCore">

    <ScrollViewer Style="{StaticResource PageScrollViewer}" Padding="24">
        <StackPanel>
            <TextBlock Text="Resource Monitor" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />

            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0:F1}%'}" FontSize="28" FontWeight="Bold" Foreground="#06B6D4" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding GpuPercent, StringFormat='{}{0:F1}%'}" FontSize="28" FontWeight="Bold" Foreground="#10B981" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="FPS" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Fps, StringFormat='{}{0:F0}'}" FontSize="28" FontWeight="Bold" Foreground="#7C3AED" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Ping" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding PingMs, StringFormat='{}{0:F0} ms'}" FontSize="28" FontWeight="Bold" Foreground="#EF4444" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Height="200" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding CpuSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="GPU" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding GpuSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RAM" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <lvc:CartesianChart Series="{Binding RamSeries}" Height="150"
                                            ZoomMode="{x:Static lcm:ZoomAndPanMode.None}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Bottleneck" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding BottleneckInfo}" TextWrapping="Wrap" Opacity="0.85" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Debug overlay" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ui:ToggleSwitch IsChecked="{Binding OverlayEnabled, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
